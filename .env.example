# PocketBase
POCKETBASE_URL=https://pocketbase.example.com
# For Docker/VPS deployments where PocketBase is on the same host:
# POCKETBASE_URL=http://host.docker.internal:8090
# For this repo's VPS compose defaults (container-to-container):
# POCKETBASE_URL=http://pb_lms
# VPS compose URL precedence: POCKETBASE_URL -> POCKETBASE_PUBLIC_URL -> http://pb_lms
# If using this repo's docker-compose defaults, you can omit POCKETBASE_URL
# because LMS will use http://pb_lms:8090 internally.
# HTTPS reverse-proxy + subpath recommended values:
# POCKETBASE_URL=https://api.example.com/lms
# POCKETBASE_PUBLIC_URL=https://api.example.com/lms
POCKETBASE_PUBLIC_URL=https://api.example.com/lms
POCKETBASE_SUPERUSER_EMAIL=admin@example.com
POCKETBASE_SUPERUSER_PASSWORD=replace-with-strong-password

# LMS auth/session
LMS_AUTH_SECRET=replace-with-strong-random-secret

# Backblaze B2 (S3-compatible) — server-only
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004
B2_KEY_ID=your-b2-key-id
B2_APP_KEY=your-b2-app-key
B2_BUCKET=your-bucket-name

# CDN in front of B2 — public, safe to expose
NEXT_PUBLIC_B2_CDN_URL=https://cdn.example.com/vanguard

